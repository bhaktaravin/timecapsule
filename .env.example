# 32-byte master key, hex-encoded (64 characters). Generate with:
# openssl rand -hex 32
MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

DATABASE_URL=sqlite:timecapsule.db?mode=rwc
HOST=127.0.0.1
PORT=3000
RUST_LOG=timecapsule=debug,tower_http=debug
DEV_MODE=1

# Mailtrap Email Sending API (recommended if you have an API token)
# Get token from: Email Sending → Integration → API
APP_BASE_URL=http://127.0.0.1:3000
MAILTRAP_API_TOKEN=paste_your_api_token_here
MAILTRAP_FROM_EMAIL=hello@demomailtrap.co
MAILTRAP_FROM_NAME=Timecapsule

# Alternative: Mailtrap Email Testing SMTP (fake inbox, no real delivery)
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=Timecapsule <noreply@timecapsule.local>
